<!doctype html>
<html lang="{{ book.language }}">
<head>
<meta charset="utf-8">
<title>{{ book.title }}</title>
</head>
{# Recipes are flat <h1> chapters (no wrapping <section>): pandoc's
   --split-level=1 only splits on top-level headings, so a wrapper would bundle
   every recipe into one file and break its cross-references in epubcheck. #}
<body>

<h1 id="introduction">{{ intro.title }}</h1>
{% if intro.from_name %}<p class="byline">{{ book.labels.from }} {{ intro.from_name }}{% if intro.from_org %} ({{ intro.from_org }}){% endif %}</p>{% endif %}
{% for p in intro.body_html %}<p>{{ p }}</p>{% endfor %}

{% for r in recipes %}
<h1 id="{{ r.slug }}">{{ r.title }}</h1>
{% if (r.has_story and r.author.name) or r.credits_line %}
<p class="byline">{{ (book.labels.recipe_by + ' ' + r.author.name + (' (' + r.author.org + ')' if r.author.org else '')) if (r.has_story and r.author.name) else (book.labels.recipe_from + ' ' + r.credits_line) }}</p>
{% endif %}
{% if r.has_story %}{% for p in r.story_html %}<p>{{ p }}</p>{% endfor %}{% endif %}
{% if r.illustration_url %}<figure class="hero"><img src="{{ r.illustration_url }}" alt="{{ r.title }}"></figure>{% endif %}

<h2>{{ book.labels.ingredients }}</h2>
{{ r.ingredients_html }}
{% if r.servings %}<p class="yields"><strong>{{ book.labels.yields }}:</strong> {{ r.servings }}</p>{% endif %}

<h2>{{ book.labels.directions }}</h2>
{{ r.directions_html }}

{% if r.notes_html %}
<h2>{{ book.labels.notes }}</h2>
{{ r.notes_html }}
{% endif %}

{% for s in r.extra_sections %}
<h2>{{ s.title }}</h2>
{{ s.html }}
{% endfor %}

{% if r.attribution %}<p class="attribution">{{ r.attribution }}</p>{% endif %}
{% endfor %}

</body>
</html>
